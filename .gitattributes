# Normalise line endings to LF in the repository (important for Docker/CI Linux).
* text=auto eol=lf
# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pt binary
*.pth binary
*.onnx binary
*.h5 binary
*.keras binary
# Generated lockfiles: keep but mark as such for review tooling.
uv.lock linguist-generated=true
pnpm-lock.yaml linguist-generated=true
backend/metrics/cnn/cnn_resnet18.pt filter=lfs diff=lfs merge=lfs -text
backend/metrics/lstm/lstm_climate.keras filter=lfs diff=lfs merge=lfs -text
backend/metrics/lstm/scaler.npz filter=lfs diff=lfs merge=lfs -text
backend/metrics/ensemble/ensemble.joblib filter=lfs diff=lfs merge=lfs -text
