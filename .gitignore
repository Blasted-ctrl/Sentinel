# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Virtualenvs
.venv/
venv/
env/

# uv
# (uv.lock IS committed for reproducibility)

# Node / Next.js
node_modules/
.next/
out/
.pnpm-store/
*.tsbuildinfo

# ML model weights are large, so they are ignored by default. The four weights
# the app needs to *serve* are the exception: they're committed via Git LFS (see
# .gitattributes) so the backend can deploy self-contained. metrics.json IS committed.
*.pt
*.pth
*.onnx
*.h5
*.keras
*.npz
*.joblib
# Serving weights — committed via Git LFS so a fresh deploy has the models.
!backend/metrics/cnn/cnn_resnet18.pt
!backend/metrics/lstm/lstm_climate.keras
!backend/metrics/lstm/scaler.npz
!backend/metrics/ensemble/ensemble.joblib
# Downloaded datasets + training artifacts (scoped so the src/sentinel/data
# package is NOT ignored).
/data/
/artifacts/
/backend/data/
/backend/artifacts/

# Environment — never commit real secrets
.env
.env.local
.env.*.local
!.env.example

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Docker / logs
*.log
