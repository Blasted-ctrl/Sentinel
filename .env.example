# ---------------------------------------------------------------------------
# Sentinel environment configuration. Copy to `.env` and fill in real values.
# Never commit `.env`. Only this example file is tracked.
# ---------------------------------------------------------------------------

# --- Database (PostGIS) ---
# In docker-compose the host is `db`; locally it is `localhost`.
DATABASE_URL=postgresql+psycopg://sentinel:sentinel@localhost:5432/sentinel

# --- Redis (Celery broker / cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (S3 in prod, MinIO in dev) ---
# For MinIO dev, point the endpoint at the local container.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=sentinel-tiles
S3_REGION=us-east-1

# --- NASA FIRMS (fire detections) ---
# Free MAP_KEY: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=your-firms-map-key
# Default FIRMS product/source for active-fire detections.
FIRMS_SOURCE=VIIRS_SNPP_NRT

# --- Open-Meteo (weather features; no key required) ---
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive

# --- STAC imagery (Sentinel-2 L2A via Element84 Earth Search; no key required) ---
STAC_API_URL=https://earth-search.aws.element84.com/v1
STAC_COLLECTION=sentinel-2-l2a
# Max cloud cover (%) when selecting scenes.
STAC_MAX_CLOUD_COVER=30

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false
